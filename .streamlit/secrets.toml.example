# Copie este arquivo para .streamlit/secrets.toml (local)
# ou cole o conteúdo em "Manage app → Settings → Secrets" (Streamlit Cloud)

[app]
password = "senha_que_juliano_vai_usar_pra_entrar"

[data]
# URLs de download direto dos xlsx
# Como obter no OneDrive:
#   1) Botão direito no arquivo → Compartilhar → Copiar link (com "Qualquer pessoa com o link")
#   2) Colar aqui a URL do link
#   3) TROCAR o final '?e=XXX' por '?download=1' (força download ao invés de preview)
URL_PAGAMENTOS = "https://1drv.ms/x/c/xxxxx/xxxxxx?download=1"
URL_RECEBIMENTOS = "https://1drv.ms/x/c/xxxxx/xxxxxx?download=1"
